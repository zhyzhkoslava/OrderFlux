# Dockerfile.dev
# syntax=docker/dockerfile:1.6

FROM dunglas/frankenphp:php8.4-alpine

# -----------------------------
# System dependencies
# -----------------------------
RUN apk add --no-cache \
    bash \
    git \
    unzip \
    icu-dev \
    libpq-dev \
    linux-headers \
    rabbitmq-c-dev

# -----------------------------
# PHP extensions (DEV)
# -----------------------------
RUN install-php-extensions \
    pdo_pgsql \
    intl \
    pcntl \
    opcache \
    redis \
    sockets \
    xdebug

# -----------------------------
# Composer
# -----------------------------
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# -----------------------------
# Xdebug configuration
# -----------------------------
RUN echo "zend_extension=xdebug" > /usr/local/etc/php/conf.d/xdebug.ini && \
    echo "xdebug.mode=debug,coverage" >> /usr/local/etc/php/conf.d/xdebug.ini && \
    echo "xdebug.start_with_request=yes" >> /usr/local/etc/php/conf.d/xdebug.ini && \
    echo "xdebug.client_host=host.docker.internal" >> /usr/local/etc/php/conf.d/xdebug.ini && \
    echo "xdebug.client_port=9003" >> /usr/local/etc/php/conf.d/xdebug.ini && \
    echo "xdebug.log_level=0" >> /usr/local/etc/php/conf.d/xdebug.ini

# -----------------------------
# App
# -----------------------------
WORKDIR /app
COPY . .

RUN composer install --no-interaction --prefer-dist

EXPOSE 8000

CMD ["php", "artisan", "octane:start", "--server=frankenphp", "--host=0.0.0.0", "--port=8000", "--watch"]
